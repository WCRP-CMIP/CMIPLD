def generate_root_redirect(config):
    """Generate a root index.html redirect in the repo root (parent of site_dir).

    The workflow moves site_dir -> docs/, so the redirect needs to be
    at the repo root to point visitors to docs/.
    """
    site_dir = Path(config['site_dir'])
    repo_root = site_dir.parent
    redirect_path = repo_root / 'index.html'

    if redirect_path.exists():
        print(f"[redirect] {redirect_path} already exists, skipping")
        return

    redirect_path.write_text(REDIRECT_HTML, encoding='utf-8')
    print(f"[redirect] Generated root redirect at {redirect_path}")


def on_post_build(config, **kwargs):
    """MkDocs post-build hook."""
    
    # Always clean URLs
    clean_urls(config)
    
    # Generate root redirect page
    generate_root_redirect(config)
    
    # Only run auto-versioning if AUTO_VERSION is enabled
    if not os.environ.get("AUTO_VERSION"):
        return
    
    print("\n[auto_version] Checking for version deployment...")
    
    # Import and run auto_version
    scripts_dir = Path(config["docs_dir"]) / "scripts"
    sys.path.insert(0, str(scripts_dir))
    
    try:
        from auto_version import auto_deploy, show_status
        
        show_status()
        print()
        auto_deploy(force=False, push=True)
        
    except ImportError as e:
        print(f"[auto_version] Could not import auto_version: {e}")
    except Exception as e:
        print(f"[auto_version] Error: {e}")
    finally:
        sys.path.pop(0)
